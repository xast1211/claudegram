# 1. Telegram Bot Token — via @BotFather on Telegram (/newbot)
TELEGRAM_TOKEN=your_bot_token_here

# 2. Your Telegram User ID — message @userinfobot on Telegram
TELEGRAM_USER_ID=your_telegram_user_id

# 3. Absolute path to your Obsidian vault
#    CLAUDE.md must exist here for full Claudian context
VAULT_PATH=C:\Users\you\Documents\MyVault
